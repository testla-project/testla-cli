{
    "name": "@testla/cli",
    "version": "0.1.0",
    "description": "Open-Source AI Agent for developers — runs in your terminal",
    "exports": "./main.ts",
    "tasks": {
        "start": "deno run --allow-all main.ts",
        "dev": "deno run --allow-all --watch main.ts",
        "install": "deno install --allow-all --global --config deno.json -f -n testla main.ts",
        "compile": "deno compile --allow-all -o dist/testla main.ts"
    },
    "imports": {
        "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
        "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
        "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0",
        "@cliffy/table": "jsr:@cliffy/table@^1.0.0"
    },
    "lint": {
        "rules": {
            "tags": ["recommended"]
        }
    },
    "fmt": {
        "useTabs": false,
        "lineWidth": 100,
        "indentWidth": 4,
        "singleQuote": true,
        "semiColons": true
    }
}