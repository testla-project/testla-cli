{
    "name": "@testla/cli",
    "version": "0.1.0",
    "description": "Open-Source AI Agent for developers — runs in your terminal",
    "nodeModulesDir": "auto",
    "exports": "./main.ts",
    "tasks": {
        "lint": "deno lint",
        "fmt": "deno fmt",
        "start": "deno run --allow-all main.ts",
        "build": "deno compile --no-check --allow-read --allow-write -o testla main.ts",
        "dev": "deno run --allow-all --watch main.ts",
        "install": "deno install --allow-all --global --config deno.json -f -n testla main.ts",
        "compile": "deno compile --allow-all -o dist/testla main.ts",
        "compile:linux": "deno compile --allow-all --target x86_64-unknown-linux-gnu  -o dist/testla-linux-x64    main.ts",
        "compile:macos-x64": "deno compile --allow-all --target x86_64-apple-darwin       -o dist/testla-macos-x64   main.ts",
        "compile:macos-arm": "deno compile --allow-all --target aarch64-apple-darwin      -o dist/testla-macos-arm64 main.ts",
        "compile:all": "deno task compile:linux && deno task compile:macos-x64 && deno task compile:macos-arm"
    },
    "imports": {
        "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
        "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
        "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0",
        "@cliffy/table": "jsr:@cliffy/table@^1.0.0",
        "playwright": "npm:playwright@^1.49.0",
        "@std/fs": "jsr:@std/fs@^1.0.23",
        "@std/path": "jsr:@std/path@^1.1.4",
        "@ai-sdk/openai": "npm:@ai-sdk/openai@^1.3.7",
        "@ai-sdk/azure": "npm:@ai-sdk/azure@^1.3.7",
        "@ai-sdk/ollama": "npm:ollama-ai-provider@^1.2.0",
        "@ai-sdk/provider-utils": "npm:@ai-sdk/provider-utils@^2.2.4",
        "ai": "npm:ai@^4.3.2",
        "openai": "npm:openai@^3.2.1"
    },
    "lint": {
        "include": ["src/"],
        "rules": {
            "tags": ["recommended"]
        }
    },
    "fmt": {
        "useTabs": false,
        "lineWidth": 100,
        "indentWidth": 4,
        "singleQuote": true,
        "semiColons": true
    }
}
